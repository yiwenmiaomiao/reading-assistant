.nav-placeholder {
  width: 100%;
}

.app-nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 1000;
  color: #10131f;
  background: rgba(247, 248, 252, 0.86);
  border-bottom: 1rpx solid rgba(226, 232, 240, 0.82);
  backdrop-filter: blur(28rpx);
}

.nav-transparent {
  background: rgba(247, 248, 252, 0.62);
}

.status-space {
  width: 100%;
}

.nav-row {
  display: flex;
  align-items: center;
  min-height: 44px;
  padding: 0 28rpx;
}

.nav-back,
.nav-right {
  display: flex;
  align-items: center;
  justify-content: flex-start;
  width: 88rpx;
  height: 72rpx;
  margin: 0;
  padding: 0;
  line-height: 1;
  background: transparent;
  border: 0;
}

.nav-back {
  color: #10131f;
}

.nav-back::after {
  border: 0;
}

.nav-back-placeholder {
  opacity: 0;
}

.back-icon {
  display: block;
  width: 58rpx;
  height: 58rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.74);
  box-shadow: inset 0 0 0 1rpx rgba(15, 23, 42, 0.08), 0 8rpx 22rpx rgba(15, 23, 42, 0.08);
  font-size: 52rpx;
  line-height: 50rpx;
  text-align: center;
}

.nav-title {
  flex: 1;
  min-width: 0;
  overflow: hidden;
  color: #10131f;
  font-size: 32rpx;
  font-weight: 800;
  text-align: center;
  text-overflow: ellipsis;
  white-space: nowrap;
}
