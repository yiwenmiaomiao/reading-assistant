
.profile-gate-mask {
  position: fixed;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 1600;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 48rpx 32rpx;
  background: rgba(0, 0, 0, 0.3);
  backdrop-filter: blur(8rpx);
  -webkit-backdrop-filter: blur(8rpx);
}

.profile-gate-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 100%;
  max-width: 640rpx;
  padding: 58rpx 36rpx;
  background: rgba(255, 255, 255, 1);
  border: 2rpx solid rgba(255, 255, 255, 0.86);
  border-radius: 42rpx;
  box-shadow:
    0 24rpx 60rpx rgba(31, 38, 135, 0.08),
    inset 0 2rpx 4rpx rgba(255, 255, 255, 0.9);
}

.profile-gate-kicker {
  color: #8049b4;
  font-size: 24rpx;
  font-weight: 300;
  letter-spacing: 4rpx;
}

.profile-gate-title {
  margin-top: 18rpx;
  color: #10131f;
  font-size: 44rpx;
  font-weight: 400;
  line-height: 1.25;
  text-align: center;
}

.profile-gate-desc {
  max-width: 560rpx;
  margin-top: 18rpx;
  color: #6b7280;
  font-size: 26rpx;
  font-weight: 300;
  line-height: 1.6;
  text-align: center;
}
/* --- 头像按钮本体 --- */
.profile-gate-avatar {
  display: flex;
  align-items: center;     /* 垂直居中 */
  justify-content: center; /* 水平居中 */
  box-sizing: border-box;  /* 确保边框计算在尺寸内 */
  
  width: 150rpx;
  height: 150rpx;
  margin: 48rpx auto 0;    /* 确保按钮在卡片里水平居中 */
  padding: 0 !important;   /* 强制干掉 button 自带的诡异内边距 */
  border-radius: 50%;
  background-color: #f3f4f6;
  border: 2rpx dashed #d1d5db;
}

/* 去除 button 的默认边框 */
.profile-gate-avatar::after {
  border: none;
}

.profile-gate-avatar-image {
  display: block;
  width: 100%;
  height: 100%;
  border-radius: 50%;
}
/* --- 提示文字（选择前展示） --- */
.profile-gate-avatar-tip {
  display: block;
  width: 110rpx;           /* 限制宽度，让 6 个字自然折成两行更美观 */
  font-size: 24rpx;
  color: #6b7280; 
  line-height: 1.4;
  text-align: center;
  white-space: pre-wrap;   /* 允许文字自然换行 */
  font-weight: 300;
}

.profile-gate-input {
  width: 520rpx;
  height: 86rpx;
  margin-top: 34rpx;
  color: #10131f;
  background: rgba(255, 255, 255, 0.62);
  border: 1rpx solid rgba(255, 255, 255, 0.86);
  border-radius: 28rpx;
  box-shadow: inset 0 2rpx 8rpx rgba(255, 255, 255, 0.8);
  font-size: 24rpx;
  font-weight: 300;
  text-align: center;
}

.profile-gate-submit {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 520rpx;
  height: 88rpx;
  margin-top: 42rpx;
  padding: 0;
  color: #5e2b97;
  background: rgba(246, 235, 255, 0.82);
  border: 1rpx solid rgba(255, 255, 255, 0.86);
  border-radius: 30rpx;
  box-shadow:
    inset 0 2rpx 4rpx rgba(255, 255, 255, 0.8),
    0 8rpx 32rpx rgba(200, 160, 255, 0.25);
  font-size: 30rpx;
  font-weight: 400;
  line-height: 88rpx;
  text-align: center;
}

.profile-gate-submit:active {
  transform: scale(0.97);
}

.profile-gate-submit.disabled,
.profile-gate-submit[disabled] {
  color: rgba(107, 114, 128, 0.62);
  background: rgba(229, 231, 235, 0.58);
  box-shadow: none;
  opacity: 0.68;
}

.profile-gate-submit.disabled:active,
.profile-gate-submit[disabled]:active {
  transform: none;
}
