/* 统一页面背景 */
.profile-page {
  min-height: 0;
  background-color: #fdfdfe;
  background-image: 
    radial-gradient(circle at 80% 10%, rgba(255, 180, 200, 0.25) 0%, transparent 45%),
    radial-gradient(circle at 15% 30%, rgba(200, 160, 255, 0.2) 0%, transparent 50%),
    radial-gradient(circle at 85% 85%, rgba(160, 200, 255, 0.25) 0%, transparent 45%),
    radial-gradient(circle at 20% 90%, rgba(255, 200, 220, 0.25) 0%, transparent 50%);
  background-attachment: fixed;
}

/* 统一面板毛玻璃 */
.stat-panel,
.menu-list {
  background: rgba(255, 255, 255, 0.45);
  backdrop-filter: blur(30rpx);
  -webkit-backdrop-filter: blur(30rpx);
  border: 2rpx solid rgba(255, 255, 255, 0.8);
  border-radius: 26rpx;
  box-shadow: 
    0 16rpx 40rpx rgba(31, 38, 135, 0.05), 
    inset 0 2rpx 4rpx rgba(255, 255, 255, 0.9);
}

/* --- 头部用户信息区域：改为垂直居中排列 --- */
.profile-head {
  display: flex;
  flex-direction: column; /* 核心：改为垂直列排列 */
  align-items: center;    /* 核心：水平方向居中对齐 */
  justify-content: center;
  gap: 20rpx;             /* 头像与下方文字整体的间距 */
  padding: 48rpx 4rpx 40rpx; /* 适当加深顶部内边距，让垂直布局更舒展 */
}

/* 头像组件（垂直排列时可以稍微放大一点，更显精致，你也可以保留原大小） */
.profile-avatar {
  width: 128rpx;          
  height: 128rpx;
  font-size: 20rpx;
  line-height: 1.25;
}

.profile-avatar-btn {
  overflow: hidden;
  padding: 0;
  border-radius: 50%;
}

.profile-avatar-image {
  display: block;
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.profile-avatar-tip {
  display: block;
  width: 86rpx;
  color: rgba(255, 255, 255, 0.96);
  font-size: 20rpx;
  font-weight: 300;
  line-height: 1.25;
  text-align: center;
}

/* 用户信息包裹层 */
.profile-info {
  display: flex;
  flex-direction: column;
  align-items: center;    /* 确保里面的名字和签名也居中 */
  text-align: center;     /* 核心：多行文本时文字居中对齐 */
  width: 100%;
}

.profile-name-input {
  width: 420rpx;
  height: 60rpx;
  color: #10131f;
  font-size: 42rpx;       /* 稍微放大一点点更突出 */
  font-weight: 400;
  text-align: center;
  background: transparent;
  border: 0;
}

/* 个性签名/简介 */
.profile-bio {
  margin-top: 12rpx;
  color: #6b7280;
  font-size: 26rpx;
  font-weight: 300;
  line-height: 1.5;
  max-width: 520rpx;      /* 限制个性签名的最大宽度，防止字数太多时铺得太满，换行居中更好看 */
}

.stat-panel {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  row-gap: 24rpx;
  margin-bottom: 28rpx;
  padding: 26rpx 8rpx;
}

.profile-stat {
  text-align: center;
}

.profile-stat-number {
  display: block;
  color: #8049b4;
  font-size: 34rpx;
  font-weight: 400;
}

.profile-stat-label {
  display: block;
  margin-top: 8rpx;
  color: #6b7280;
  font-size: 22rpx;
  font-weight: 300;
}

.menu-list {
  overflow: hidden;

}

.menu-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 104rpx;
  padding: 0 28rpx;
  color: #10131f;
  border-bottom: 1rpx solid #f1f3f6;
  font-size: 30rpx;
  font-weight: 300;
  text-align: left;
}

.menu-arrow {
  color: #c0c4cc;
  font-size: 44rpx;
}
