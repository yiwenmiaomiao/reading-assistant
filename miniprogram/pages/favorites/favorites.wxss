@import "../../styles/note-detail.wxss";

.favorites-page {
  min-height: 0;
  background-color: #fdfdfe;
  background-image: 
    radial-gradient(circle at 80% 10%, rgba(255, 180, 200, 0.25) 0%, transparent 45%),
    radial-gradient(circle at 15% 30%, rgba(200, 160, 255, 0.2) 0%, transparent 50%),
    radial-gradient(circle at 85% 85%, rgba(160, 200, 255, 0.25) 0%, transparent 45%),
    radial-gradient(circle at 20% 90%, rgba(255, 200, 220, 0.25) 0%, transparent 50%);
  background-attachment: fixed;
}

.small-avatar {
  width: 42rpx;
  height: 42rpx;
  font-size: 20rpx;
}

.favorite-btn {
  margin-top: 28rpx !important;
  margin-bottom: 0 !important;
  display: flex !important;
  clear: both !important;
}

.note-content + .favorite-btn,
.note-content + view .favorite-btn {
  margin-top: 28rpx !important;
}
