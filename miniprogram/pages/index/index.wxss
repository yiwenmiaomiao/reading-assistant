.home-page {
  min-height: 0;
  background-color: #fdfdfe;
  background-image: 
    radial-gradient(circle at 80% 10%, rgba(255, 180, 200, 0.25) 0%, transparent 45%),
    radial-gradient(circle at 15% 30%, rgba(200, 160, 255, 0.2) 0%, transparent 50%),
    radial-gradient(circle at 85% 85%, rgba(160, 200, 255, 0.25) 0%, transparent 45%),
    radial-gradient(circle at 20% 90%, rgba(255, 200, 220, 0.25) 0%, transparent 50%);
  background-attachment: fixed; 
}

.hero {
  display: flex;
  align-items: flex-end;
  min-height: 260rpx;
  padding: 36rpx 8rpx 30rpx;
}

.hero-kicker {
  color: #8049b4;
  font-size: 24rpx;
  font-weight: 400;
}

.hero-title {
  max-width: 620rpx;
  margin-top: 14rpx;
  color: #10131f;
  font-size: 50rpx;
  font-weight: 300;
  line-height: 1.25;
}

.stats-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
}

/* 更新统计卡片为毛玻璃 */
.stat-card {
  min-height: 180rpx;
  padding: 26rpx;
  border-radius: 26rpx;
  
  /* 毛玻璃核心 */
  background: rgba(255, 255, 255, 0.45);
  backdrop-filter: blur(30rpx);
  -webkit-backdrop-filter: blur(30rpx);
  border: 2rpx solid rgba(255, 255, 255, 0.8);
  box-shadow: 
    0 16rpx 40rpx rgba(31, 38, 135, 0.05), 
    inset 0 2rpx 4rpx rgba(255, 255, 255, 0.9);
}

.stat-label,
.stat-note {
  display: block;
  color: #6b7280;
  font-size: 24rpx;
  font-weight: 300;
}

.stat-number {
  display: block;
  margin: 18rpx 0 10rpx;
  color: #8049b4;
  font-size: 58rpx;
  font-weight: 400;
  line-height: 1;
}

.ranking-card {
  padding: 10rpx 0 0;

  /* 毛玻璃核心 */
  background: rgba(255, 255, 255, 0.45);
  backdrop-filter: blur(30rpx);
  -webkit-backdrop-filter: blur(30rpx);
  border: 2rpx solid rgba(255, 255, 255, 0.8);
  box-shadow: 
    0 16rpx 40rpx rgba(31, 38, 135, 0.05), 
    inset 0 2rpx 4rpx rgba(255, 255, 255, 0.9);
}

.rank-row {
  display: flex;
  align-items: center;
  gap: 18rpx;
  min-height: 108rpx;
  padding: 0 28rpx;
  border-bottom: 1rpx solid #f1f3f6;
}

.rank-index {
  width: 42rpx;
  color: #8049b4;
  font-size: 30rpx;
  font-weight: 300;
  text-align: center;
}

.rank-user {
  flex: 1;
  min-width: 0;
}

.rank-name {
  color: #10131f;
  font-size: 28rpx;
  font-weight: 300;
}

.rank-sub {
  margin-top: 6rpx;
  color: #6b7280;
  font-size: 24rpx;
  font-weight: 300;
}

.rank-count {
  color: #10131f;
  font-size: 28rpx;
  font-weight: 300;
}

.ranking-more {
  padding: 26rpx;
  color: #8049b4;
  font-size: 26rpx;
  font-weight: 300;
  text-align: center;
}

.compact-empty {
  padding: 44rpx 28rpx;
}

.profile-gate-mask {
  position: fixed;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 1600;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 48rpx 32rpx;
  background: rgba(253, 253, 254, 0.68);
  backdrop-filter: blur(28rpx);
  -webkit-backdrop-filter: blur(28rpx);
}

.profile-gate-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 100%;
  max-width: 640rpx;
  padding: 58rpx 36rpx;
  background: rgba(255, 255, 255, 0.62);
  border: 2rpx solid rgba(255, 255, 255, 0.86);
  border-radius: 42rpx;
  box-shadow:
    0 24rpx 60rpx rgba(31, 38, 135, 0.08),
    inset 0 2rpx 4rpx rgba(255, 255, 255, 0.9);
}

.profile-gate-kicker {
  color: #8049b4;
  font-size: 24rpx;
  font-weight: 300;
  letter-spacing: 4rpx;
}

.profile-gate-title {
  margin-top: 18rpx;
  color: #10131f;
  font-size: 44rpx;
  font-weight: 400;
  line-height: 1.25;
  text-align: center;
}

.profile-gate-desc {
  max-width: 560rpx;
  margin-top: 18rpx;
  color: #6b7280;
  font-size: 26rpx;
  font-weight: 300;
  line-height: 1.6;
  text-align: center;
}

.profile-gate-avatar {
  width: 150rpx;
  height: 150rpx;
  margin-top: 48rpx;
  padding: 0;
  border-radius: 50%;
  font-size: 22rpx;
  line-height: 1.25;
}

.profile-gate-avatar-image {
  display: block;
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.profile-gate-avatar-tip {
  display: block;
  width: 96rpx;
  color: rgba(255, 255, 255, 0.96);
  font-size: 22rpx;
  font-weight: 300;
  line-height: 1.25;
  text-align: center;
}

.profile-gate-input {
  width: 520rpx;
  height: 86rpx;
  margin-top: 34rpx;
  color: #10131f;
  background: rgba(255, 255, 255, 0.62);
  border: 1rpx solid rgba(255, 255, 255, 0.86);
  border-radius: 28rpx;
  box-shadow: inset 0 2rpx 8rpx rgba(255, 255, 255, 0.8);
  font-size: 30rpx;
  font-weight: 300;
  text-align: center;
}

.profile-gate-submit {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 520rpx;
  height: 88rpx;
  margin-top: 42rpx;
  padding: 0;
  color: #5e2b97;
  background: rgba(246, 235, 255, 0.82);
  border: 1rpx solid rgba(255, 255, 255, 0.86);
  border-radius: 30rpx;
  box-shadow:
    inset 0 2rpx 4rpx rgba(255, 255, 255, 0.8),
    0 8rpx 32rpx rgba(200, 160, 255, 0.25);
  font-size: 30rpx;
  font-weight: 400;
  line-height: 88rpx;
  text-align: center;
}

.profile-gate-submit:active {
  transform: scale(0.97);
}
