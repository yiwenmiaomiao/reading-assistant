.ranking-page {
  min-height: 0;
  background-color: #fdfdfe;
  background-image: 
    radial-gradient(circle at 80% 10%, rgba(255, 180, 200, 0.25) 0%, transparent 45%),
    radial-gradient(circle at 15% 30%, rgba(200, 160, 255, 0.2) 0%, transparent 50%),
    radial-gradient(circle at 85% 85%, rgba(160, 200, 255, 0.25) 0%, transparent 45%),
    radial-gradient(circle at 20% 90%, rgba(255, 200, 220, 0.25) 0%, transparent 50%);
  background-attachment: fixed;
}

.rank-detail-row {
  /* 毛玻璃核心 */
  background: rgba(255, 255, 255, 0.45);
  backdrop-filter: blur(30rpx);
  -webkit-backdrop-filter: blur(30rpx);
  border: 2rpx solid rgba(255, 255, 255, 0.8);
  box-shadow: 
    0 16rpx 40rpx rgba(31, 38, 135, 0.05), 
    inset 0 2rpx 4rpx rgba(255, 255, 255, 0.9);
}

.rank-detail-head {
  padding: 18rpx 4rpx 28rpx;
}

.head-title {
  color: #10131f;
  font-size: 50rpx;
  font-weight: 800;
}

.head-sub {
  margin-top: 10rpx;
  color: #6b7280;
  font-size: 26rpx;
  line-height: 1.5;
}

.rank-detail-row {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.rank-number {
  width: 50rpx;
  color: #8049b4;
  font-size: 34rpx;
  font-weight: 800;
  text-align: center;
}

.rank-person {
  flex: 1;
  min-width: 0;
}

.rank-name {
  font-size: 30rpx;
  font-weight: 300;
}

.rank-sub {
  margin-top: 6rpx;
  color: #6b7280;
  font-size: 24rpx;
}

.rank-note-count {
  color: #10131f;
  font-size: 30rpx;
  font-weight: 300;
}
