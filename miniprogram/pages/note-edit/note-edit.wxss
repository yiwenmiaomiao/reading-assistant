/* 1. 宽度兼容性：确保容器宽度受控 */
.edit-page {
  width: 100vw;
  padding: 24rpx 24rpx calc(50rpx + env(safe-area-inset-bottom)) 24rpx !important;
  box-sizing: border-box;
  background-color: #fdfdfe;
  background-image: 
    radial-gradient(circle at 80% 10%, rgba(255, 180, 200, 0.25) 0%, transparent 45%),
    radial-gradient(circle at 15% 30%, rgba(200, 160, 255, 0.2) 0%, transparent 50%),
    radial-gradient(circle at 85% 85%, rgba(160, 200, 255, 0.25) 0%, transparent 45%),
    radial-gradient(circle at 20% 90%, rgba(255, 200, 220, 0.25) 0%, transparent 50%);
  background-attachment: fixed;
  min-height: 0;
}

/* 统一所有占位文字的字重、字号与系统默认浅灰色 */
.edit-placeholder,
.textarea-placeholder {
  font-weight: 300 !important;
  color: #a0a5b5 !important; /* 你想要的占位符灰色 */
}

input-placeholder, 
textarea-placeholder {
  font-weight: 300 !important;
  color: #a0a5b5 !important;
  font-size: 28rpx !important;
}


/* 底部操作区样式 */
.footer-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 50rpx;
  margin-bottom: 0 !important;
  width: 100%;
}

/* --- 底部操作区按钮：全局基础毛玻璃形态 --- */
.footer-actions button {
  position: relative;
  flex: 1; /* 强制两按钮各占一半宽度 */
  height: 82rpx !important;
  margin: 0 !important;
  border-radius: 30rpx !important;
  
  /* 核心：清透的玻璃质感中心，去掉原有实色底 */
  background: rgba(255, 255, 255, 0.15) !important; 
  backdrop-filter: blur(24rpx);
  -webkit-backdrop-filter: blur(24rpx);
  border: none !important;
  z-index: 1;
  font-weight: bold;
  
  /* 基础的玻璃边缘高光反光 */
  box-shadow: inset 0 2rpx 4rpx rgba(255, 255, 255, 0.8) !important;
}

/* 1. 左侧“取消”按钮 (幽灵色调边缘光) */
.footer-actions button:first-child {
  color: #6b7280 !important;
  font-weight: 400;
  /* 添加轻微的灰色外发光 */
  box-shadow: 
    inset 0 2rpx 4rpx rgba(255, 255, 255, 0.8),
    0 8rpx 24rpx rgba(107, 114, 128, 0.1) !important;
}
.footer-actions button:first-child::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  border-radius: 30rpx;
  padding: 3rpx; /* 发光边缘厚度 */
  background: linear-gradient(135deg, #e5e7eb, #9ca3af);
  -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
  -webkit-mask-composite: xor;
  mask-composite: exclude;
  pointer-events: none;
}

/* 2. 右侧“保存”按钮 (主色调蓝紫边缘光) */
.footer-actions button:last-child {
  color: #5E2B97 !important;
  font-weight: 400;
  /* 强烈的蓝紫色外层环境光晕 */
  box-shadow:
    inset 0 2rpx 4rpx rgba(255, 255, 255, 0.8),
    0 8rpx 32rpx rgba(200, 160, 255, 0.25) !important;
}
.footer-actions button:last-child::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  border-radius: 30rpx;
  padding: 3rpx;
  background: linear-gradient(90deg, #ffb4c8, #c8a0ff, #a0c8ff, #ffe0e9, #ffb4c8);
  -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
  -webkit-mask-composite: xor;
  mask-composite: exclude;
  pointer-events: none;
}

/* 输入框区域统一毛玻璃 */
.field {
  margin-bottom: 28rpx;
  padding: 24rpx;
  border-radius: 26rpx;
  
  /* 毛玻璃核心 */
  background: rgba(255, 255, 255, 0.45);
  backdrop-filter: blur(30rpx);
  -webkit-backdrop-filter: blur(30rpx);
  border: 2rpx solid rgba(255, 255, 255, 0.8);
  box-shadow: 
    0 16rpx 40rpx rgba(31, 38, 135, 0.05), 
    inset 0 2rpx 4rpx rgba(255, 255, 255, 0.9);
}



.field-label {
  margin-bottom: 14rpx;
  color: #10131f;
  font-size: 28rpx;
  font-weight: 400;
}

/* 编辑页所有输入框、文本域：font-weight 300 */
.input, .textarea {
  font-weight: 300 !important; /* 输入后的文字保持正常的粗细 */
  color: #10131f !important;    /* 输入后的文字保持正常的深色 */
}

.main-textarea {
  min-height: 330rpx;
}

.reflection-textarea {
  min-height: 190rpx;
}

.counter,
.image-tip {
  margin-top: 10rpx;
  color: #878686;
  font-size: 24rpx;
  font-weight: 300;
  text-align: right;
}

/* 2. 标签：统一为卡片中的毛玻璃圆角方块 */
.tag-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  min-height: 56rpx;
}

.tag {
  /* 基础布局：圆角方形感，稍微增加 padding 使其更饱满 */
  padding: 14rpx 28rpx;
  border-radius: 20rpx; /* 参考图片的圆角方形弧度 */
  
  /* 文字：深紫色，稍微加粗增加辨识度 */
  font-size: 24rpx;
  font-weight: 300;
  color: #5E2B97; /* 优雅的深紫色 */
  letter-spacing: 0.5rpx;
  
  /* 核心：粉紫调毛玻璃基底 */
  background: linear-gradient(135deg, rgba(255, 180, 200, 0.15), rgba(200, 150, 255, 0.15));
  backdrop-filter: blur(20rpx);
  
  /* 玻璃质感的高光边缘与微弱投影 */
  border: 1.5rpx solid rgba(255, 255, 255, 0.85); /* 顶部和左侧通常需要更亮的反光 */
  box-shadow: 
    0 6rpx 16rpx rgba(175, 82, 222, 0.06),       /* 外部极弱的粉紫投影 */
    inset 0 2rpx 8rpx rgba(255, 255, 255, 0.7); /* 内部顶部的高光内发光 */
}

.tag-selected {
  /* 激活态：延续粉紫温柔感 */
  background: linear-gradient(135deg, rgba(255, 180, 200, 0.4), rgba(200, 150, 255, 0.4)) !important;
  border-color: rgba(255, 255, 255, 0.9) !important;
  color: #4A1D7B !important;
  box-shadow: 0 4rpx 12rpx rgba(161, 140, 209, 0.2);
}

/* 统一渐变按钮 */
.gradient-btn {
  flex: 1; /* 均分宽度 */
  height: 82rpx !important; /* 强制高度统一 */
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 30rpx !important;
  font-weight: 600;
  color: #fff;
  background: linear-gradient(135deg, #ff999c, #A18CD1) !important;
  border: none;
  font-size: 28rpx;
  margin: 0 !important; /* 清除所有默认外边距 */
}

/* 3. 标签区的“添加”按钮：宽度适配内容 */
.tag-create {
  display: flex;
  gap: 14rpx;
  margin-top: 12rpx;
}

.tag-input {
  flex: 1;
  font-weight: 300;
}

/* --- 3. 标签区的“添加”按钮：粉紫玻璃流光 --- */
.add-tag-btn {
  position: relative;
  flex: 0 0 auto;
  padding: 0 32rpx !important;
  height: 82rpx !important;
  border-radius: 30rpx !important;

  /* 玻璃质感中心 */
  background: rgba(255, 255, 255, 0.15) !important;
  backdrop-filter: blur(24rpx);
  -webkit-backdrop-filter: blur(24rpx);
  border: none !important;
  z-index: 1;

  color: #5E2B97 !important;
  font-size: 26rpx;
  font-weight: 400;

  /* 同发布笔记按钮阴影 */
  box-shadow:
    inset 0 2rpx 4rpx rgba(255, 255, 255, 0.8),
    0 8rpx 32rpx rgba(200, 160, 255, 0.25) !important;
}

.add-tag-btn::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  border-radius: 30rpx;
  padding: 3rpx;
  /* 同发布笔记按钮边框渐变 */
  background: linear-gradient(90deg, #ffb4c8, #c8a0ff, #a0c8ff, #ffe0e9, #ffb4c8) !important;
  -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
  -webkit-mask-composite: xor;
  mask-composite: exclude;
  pointer-events: none;
}

.image-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 14rpx;
}

.image-wrap,
.add-image {
  position: relative;
  width: 100%;
  height: 206rpx;
  overflow: hidden;
  background: #f9f2fd;
  border: 1rpx dashed #e2c3ff;
  border-radius: 16rpx;
}

.edit-image {
  width: 100%;
  height: 100%;
}

.remove-image {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 42rpx;
  height: 42rpx;
  color: #ffffff;
  background: rgba(17, 24, 39, 0.62);
  border-radius: 50%;
  font-size: 30rpx;
  line-height: 42rpx;
  text-align: center;
}

.add-image {
  color: #5E2B97;
  font-size: 60rpx;
  line-height: 198rpx;
  text-align: center;
}

.actions {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  margin-top: 44rpx;
}

.delete-btn {
  background: linear-gradient(135deg, #ffef73, #ff6c6c) !important;
}

/* 5. iPhone 底部安全区适配（最重要） */
.safe-area-spacer {
  display: none !important;
}

/* 修正添加按钮高度，使其对齐 */
.add-tag-btn {
  width: 160rpx !important;
  height: 82rpx !important;
}
