/* --- 1. 统一页面背景（仙气粉紫白不规则弥散光晕） --- */
.achievements-page {
  box-sizing: border-box;
  padding: 30rpx 28rpx;
  min-height: 0;
  
  /* 底色设为偏白的极浅灰蓝 */
  background-color: #fdfdfe;
  
  /* 叠加四个不同位置的径向渐变，模拟粉、紫、蓝的不规则光晕块 */
  background-image: 
    radial-gradient(circle at 80% 10%, rgba(255, 180, 200, 0.25) 0%, transparent 45%),
    radial-gradient(circle at 15% 30%, rgba(200, 160, 255, 0.2) 0%, transparent 50%),
    radial-gradient(circle at 85% 85%, rgba(160, 200, 255, 0.25) 0%, transparent 45%),
    radial-gradient(circle at 20% 90%, rgba(255, 200, 220, 0.25) 0%, transparent 50%);
  background-attachment: fixed; 
}

/* 宫格布局 */
.achievement-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 24rpx;
}

/* --- 2. 基础卡片：未激活状态的毛玻璃 --- */
.achievement-card {
  min-height: 180rpx;
  padding: 28rpx;
  border-radius: 32rpx; /* 稍微放大圆角更有果冻感 */
  box-sizing: border-box;
  transition: all 0.4s ease;
  
  /* 基础毛玻璃 */
  background: rgba(255, 255, 255, 0.25); /* 稍微降低透明度，拉开与激活态的差距 */
  backdrop-filter: blur(30rpx);
  -webkit-backdrop-filter: blur(30rpx);
  border: 2rpx solid rgba(255, 255, 255, 0.5); /* 浅白色切边 */
  box-shadow: 0 8rpx 24rpx rgba(31, 38, 135, 0.02);
}

/* 未激活状态的文字颜色略微淡化 */
.achievement-title {
  color: #7f8c8d;
  font-size: 30rpx;
  font-weight: 800;
}

.achievement-desc {
  margin-top: 14rpx;
  color: #95a5a6;
  font-size: 24rpx;
  line-height: 1.5;
}

/* --- 3. 已激活状态（纯净毛玻璃主板，内部彻底静止） --- */
.achievement-card.active {
  position: relative;
  overflow: hidden;
  border-color: transparent;
  transform: translateY(-4rpx); /* 激活的卡片微微浮起 */
  
  /* 核心：纯静态毛玻璃，中心不再受流动色彩干扰，完美穿透底层页面的粉紫渐变 */
  background: rgba(255, 255, 255, 0.45); 
  backdrop-filter: blur(30rpx);
  -webkit-backdrop-filter: blur(30rpx);
  
  /* 外层加上带有一点粉紫霓虹感的外发光阴影 */
  box-shadow: 
    0 16rpx 40rpx rgba(200, 160, 255, 0.2), 
    inset 0 2rpx 4rpx rgba(255, 255, 255, 0.9);
}

.achievement-card.active::before {
  content: '';
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 2;
  box-sizing: border-box;
  padding: 4rpx;
  border-radius: 32rpx;
  background: linear-gradient(90deg, #ffb4c8, #c8a0ff, #a0c8ff, #ffe0e9, #ffb4c8);
  background-size: 200% 100%;
  animation: achievementBorderFlow 3s linear infinite;
  -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
  -webkit-mask-composite: xor;
  mask-composite: exclude;
  pointer-events: none;
}

.achievement-card.active .achievement-title,
.achievement-card.active .achievement-desc {
  position: relative;
  z-index: 3;
}

/* 激活状态的文字高亮（保持原样） */
.achievement-card.active .achievement-title {
  color: #10131f; 
  text-shadow: 0 2rpx 4rpx rgba(255, 255, 255, 0.5);
}

.achievement-card.active .achievement-desc {
  color: #4b5563; 
}

@keyframes achievementBorderFlow {
  0% {
    background-position: 0% 0%;
  }

  100% {
    background-position: -200% 0%;
  }
}

/* --- 年份标题样式 --- */
.year-title {
  font-size: 34rpx;
  font-weight: 800;
  color: #5E2B97;
  margin: 10rpx 0 24rpx 10rpx;
  text-shadow: 0 2rpx 4rpx rgba(255, 255, 255, 0.6);
}

/* 如果有多个年份，后续年份顶部增加间距 */
.year-title:not(:first-child) {
  margin-top: 50rpx;
}