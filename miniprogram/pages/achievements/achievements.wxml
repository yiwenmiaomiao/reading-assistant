<app-nav title="我的成就" can-back="{{true}}"></app-nav>
<scroll-view class="page achievements-page safe-bottom" scroll-y="true" style="height: {{pageHeight}}px;" enhanced="{{true}}" bounces="{{true}}" show-scrollbar="{{false}}">
  
  <block wx:for="{{achievementYears}}" wx:key="year">
    <view class="year-title">{{item.year}}年</view>
    
    <view class="achievement-grid">
      <view 
        class="card achievement-card {{monthItem.isChampion ? 'active' : ''}}" 
        wx:for="{{item.months}}" 
        wx:for-item="monthItem" 
        wx:key="month"
      >
        <view class="achievement-title">{{monthItem.month}}月冠军</view>
        <view class="achievement-desc">月度阅读分全站第一</view>
      </view>
    </view>
  </block>

  <view style="height: 40rpx;"></view>
</scroll-view>